{
  "name": "adce-framework",
  "version": "1.0.0",
  "description": "Appetite-Driven Context Engineering framework for AI-first development",
  "main": "install.js",
  "bin": {
    "adce": "./tools/cli.js",
    "adce-install": "./install.js"
  },
  "scripts": {
