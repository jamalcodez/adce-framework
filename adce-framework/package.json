  },
  "bugs": {
    "url": "https://github.com/jamalcodez/adce-framework/issues"
  },
  "homepage": "https://github.com/jamalcodez/adce-framework#readme",
  "dependencies": {
    "chalk": "^4.1.2",
    "inquirer": "^8.2.4",
    "fs-extra": "^10.1.0"
  },
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "files": [
    "agents/",
    "templates/",
